{
  "cosmos-installer": {
    "form": [
      {
        "name": "port",
        "label": "Game port (TCP + UDP, must be open/forwarded)",
        "initialValue": "7777",
        "type": "text"
      },
      {
        "name": "apiPort",
        "label": "Reliable Messaging API TCP port (local admin; avoid public forward)",
        "initialValue": "8888",
        "type": "text"
      },
      {
        "name": "maxPlayers",
        "label": "Max players",
        "initialValue": "4",
        "type": "text"
      },
      {
        "name": "steamBeta",
        "label": "Use Steam experimental/beta branch?",
        "initialValue": "false",
        "type": "select",
        "options": [
          ["false", "No (stable)"],
          ["true", "Yes (experimental)"]
        ]
      },
      {
        "name": "dataPath",
        "label": "Where should server config/saves be stored?",
        "initialValue": "{DefaultDataPath}/satisfactory",
        "type": "text"
      },
      {
        "name": "puid",
        "label": "Host user ID (PUID)",
        "initialValue": "1000",
        "type": "text"
      },
      {
        "name": "pgid",
        "label": "Host group ID (PGID)",
        "initialValue": "1000",
        "type": "text"
      }
    ],
    "post-install": [
      {
        "type": "warning",
        "label": "Satisfactory needs substantial RAM (often 8GB+). Open TCP/UDP on the game port. Full options: https://github.com/wolveix/satisfactory-server"
      }
    ]
  },
  "minVersion": "0.9.0",
  "services": {
    "{ServiceName}": {
      "image": "wolveix/satisfactory-server:latest",
      "container_name": "{ServiceName}",
      "hostname": "{ServiceName}",
      "restart": "unless-stopped",
      "environment": [
        "MAXPLAYERS={Context.maxPlayers}",
        "PGID={Context.pgid}",
        "PUID={Context.puid}",
        "STEAMBETA={Context.steamBeta}",
        "SERVERGAMEPORT={Context.port}",
        "SERVERMESSAGINGPORT={Context.apiPort}",
        "ROOTLESS=false"
      ],
      "ports": [
        "{Context.port}:{Context.port}/tcp",
        "{Context.port}:{Context.port}/udp",
        "{Context.apiPort}:{Context.apiPort}/tcp"
      ],
      "labels": {
        "cosmos-auto-update": "true",
        "cosmos-icon": "https://exxzo.github.io/cosmos-xcore-apps/servapps/Satisfactory/icon.png",
        "xenith.lab": "game-server",
        "xenith.app": "satisfactory"
      },
      "volumes": [
        {
          "source": "{Context.dataPath}",
          "target": "/config",
          "type": "bind"
        }
      ]
    }
  }
}
